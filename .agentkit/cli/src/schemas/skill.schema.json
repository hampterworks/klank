{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-content/schemas/skill.schema.json",
  "title": "Skill frontmatter",
  "type": "object",
  "required": ["name", "description"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Lowercase letters, numbers, hyphens. Max 64 chars (Anthropic spec)."
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "Third person; what the skill does AND when to use it. Max 1024 chars (Anthropic spec)."
    },
    "when_to_use": { "type": "string" },
    "argument-hint": { "type": "string" },
    "arguments": { "type": "array" },
    "disable-model-invocation": { "type": "boolean" },
    "user-invocable": { "type": "boolean" },
    "allowed-tools": { "type": ["array", "string"] },
    "disallowed-tools": { "type": ["array", "string"] },
    "model": { "type": "string" },
    "effort": { "type": "string" },
    "context": { "type": "string" },
    "agent": { "type": "string" },
    "hooks": { "type": ["object", "array"] },
    "paths": { "type": "array", "items": { "type": "string" } },
    "shell": { "type": "string" },
    "license": { "type": "string" },
    "metadata": { "type": "object" }
  },
  "additionalProperties": true
}
